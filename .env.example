OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Use "demo" for local simulation or "http" for a real trading-system port.
TRADING_SYSTEM_GATEWAY=demo
TRADING_SYSTEM_PROTOCOL=http
TRADING_SYSTEM_HOST=127.0.0.1
TRADING_SYSTEM_PORT=8080
TRADING_SYSTEM_API_TOKEN=
TRADING_SYSTEM_VERIFY_TLS=true
TRADING_SYSTEM_REQUEST_TIMEOUT_SECONDS=25
TRADING_SYSTEM_SNAPSHOT_PATH=/systems/{system_id}/snapshot
TRADING_SYSTEM_SCENARIO_PATH=/systems/{system_id}/scenarios
TRADING_SYSTEM_RESET_PATH=/systems/{system_id}/scenarios/{correlation_id}/reset
